{
  "name": "ccisland",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "tauri:dev": "pnpm --filter @ccisland/desktop tauri:dev",
    "tauri:build": "pnpm --filter @ccisland/desktop tauri:build",
    "site:dev": "pnpm --filter @ccisland/site dev",
    "site:build": "pnpm --filter @ccisland/site build",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
