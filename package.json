{
  "name": "cc-island",
  "version": "0.1.0",
  "description": "macOS Dynamic Island for Claude Code — 灵动岛审批与进度展示",
  "main": "dist/main/index.js",
  "scripts": {
    "less": "lessc src/renderer/styles.less dist/renderer/styles.css",
    "dev": "tsc && pnpm less && cp src/renderer/index.html dist/renderer/ && electron .",
    "build": "tsc && pnpm less && cp src/renderer/index.html dist/renderer/ && electron-builder",
    "watch": "tsc --watch",
    "install-hooks": "ts-node scripts/install-hooks.ts",
    "remove-hooks": "ts-node scripts/remove-hooks.ts"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "less": "^4.6.4",
    "ts-node": "^10.9.0",
    "typescript": "5.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "build": {
    "appId": "com.cc-island.app",
    "productName": "Claude Island",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "extendInfo": {
        "LSUIElement": true
      }
    }
  }
}
